#!/usr/bin/env sh

port=8989

while getopts ":p:" opt; do
  case ${opt} in
    p)
      port=$OPTARG
      ;;
    :)
      echo "Option -${OPTARG} requires an argument."
      exit 1
      ;;
    \?)
      echo "Invalid option: -${OPTARG}"
      exit 1
      ;;
  esac
done

exec bundle exec byebug -R localhost:$port