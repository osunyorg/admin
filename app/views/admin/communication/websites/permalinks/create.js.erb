<%
if @permalink.valid?
  html = escape_javascript(render 'admin/communication/websites/permalinks/permalink', permalink: @permalink)
  %>
  var tbody = document.getElementById('previous-permalinks')
                      .getElementsByTagName('tbody')[0];
  tbody.insertAdjacentHTML("beforeend", "<%= html %>");
<%
else
  message = @permalink.errors.full_messages.to_sentence
  %>
  notyf = new Notyf();
  notyf.open({
      type: 'error',
      position: {
          x: 'center',
          y: 'bottom'
      },
      message: "<%= message %>",
      duration: 9000,
      ripple: true,
      dismissible: true
  });
  <% 
end 
%>