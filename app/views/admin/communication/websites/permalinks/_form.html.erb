<%= simple_form_for [:admin, permalink] do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="row">
    <div class="col-lg-6">
      <%= f.input :path %>
    </div>
    <div class="col-lg-6">
      <% if permalink.internal? %>
        <%= osuny_label Communication::Website::Permalink.human_attribute_name(:about) %>
        <p><%= render 'admin/communication/websites/permalinks/about', permalink: permalink %></p>
      <% else %>
        <%= f.input :target_url %>
      <% end %>
    </div>
  </div>

  <% content_for :action_bar_right do %>
    <%= cancel redirects_admin_communication_website_path(@website, website_id: nil) %>
    <%= submit f %>
  <% end %>
<% end %>
