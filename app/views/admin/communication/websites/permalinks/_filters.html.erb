<%= simple_form_for :filters, url: current_path, method: :get do |f| %>
  <%= filters_panel current_path: current_path, active_filters_count: active_filters_count do |form| %>

    <%= render_filter f,
                      :string,
                      :for_search_term,
                      label: t('search')
                      %>

    <%= render_filter f,
                      :select,
                      :for_type,
                      label: t('filters.attributes.element', element: Communication::Website::Permalink.human_attribute_name(:type).downcase),
                      collection: [
                        [Communication::Website::Permalink.human_attribute_name(:internal), "internal"],
                        [Communication::Website::Permalink.human_attribute_name(:external), "external"]
                      ]
                      %>
    <% end %>
<% end %>