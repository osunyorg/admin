[[cors]]
allowed_origins = "*"
allowed_methods = ["GET", "POST"]
allowed_headers = "*"

[[headers]]
for = ["**/*.woff2", "**/*.woff", "**/*.svg", "**/*.ttf", "**/*.otf", "**/*.eot", "**/*.js", "**/*.css"]
compress = "gzip"
[headers.values]
Cache-Control = "max-age=31536000, no-transform, public"

[[headers]]
for = ["**/*.png", "**/*.jpg", "**/*.jpeg", "**/*.gif", "**/*.webp"]
[headers.values]
Cache-Control = "max-age=31536000, no-transform, public"

<% if @website.deuxfleurs_use_dxfl_redirects? %>
<%
permalinks = @website.permalinks.not_current.not_root.ordered
permalinks.find_each do |permalink|
  from_path = permalink.path.ends_with?('/')  ? "#{permalink.path}index.html"
                                              : permalink.path
%>
[[redirects]]
from = "<%= permalink.path %>"
to = "<%= permalink.target %>"

<% end %>
<% end %>
