<% content_for :title, @website.feature_agenda_name(current_language) %>

<% content_for :title_right do %>
  <%= button_advanced do %>
    <%= link_to t('templates.create'),
                new_admin_communication_website_agenda_event_path(is_template: true),
                class: button_classes if can?(:create_template, @website) %>
    <%= link_to t('admin.move.cta'),
                move_batch_admin_communication_website_agenda_events_path,
                class: button_classes if can?(:move, Communication::Website::Post) && current_user.managed_websites.count > 1 %>
  <% end if can?(:create_template, @website) || (can?(:move, Communication::Website::Post) && current_user.managed_websites.count > 1) %>
  <%= create_link Communication::Website::Agenda::Event %>
<% end %>

<div class="d-flex justify-content-between mb-5">
  <%= render 'admin/application/components/lifecycle/pills',
              path_method: :admin_communication_website_agenda_events_path %>
  <%= render 'filters',
              current_path: admin_communication_website_agenda_events_path,
              website: @website %>
</div>
<%= render 'admin/application/components/lifecycle/label' %>

<%= render 'admin/communication/websites/agenda/events/list', events: @events %>
<%= paginate @events %>
