<%
# L'url contenant les locales (TODO doit être mise en cache)
i18n_url    = admin_vue_i18n_path
# La liste des blocs
data_url    = root_admin_communication_group_blocks_path(
                about_type: about.class.polymorphic_name,
                about_id: about.id,
                website_id: nil,
                extranet_id: nil,
                journal_id: nil)
# L'URL pour choisir un nouveau bloc
new_url     = new_admin_communication_block_path(
                about_id: about.id, 
                about_type: about.class.polymorphic_name,
                website_id: nil,
                extranet_id: nil,
                journal_id: nil) if can? :create, Communication::Block
# L'URL pour ordonner les blocs
reorder_url = reorder_admin_communication_blocks_path(
                website_id: nil,
                extranet_id: nil,
                journal_id: nil)
%>
<div 
  id="blocks-editor-app"
  data-i18n-url="<%= i18n_url %>"
  data-data-url="<%= data_url %>"
  data-new-url="<%= new_url %>"
  data-reorder-url="<%= reorder_url %>">
</div>
<%= render 'admin/communication/blocks/group/editor/paste', about: about  %>
<%= render 'admin/communication/blocks/group/editor/reset', about: about  %>