<%
label = t('admin.communication.blocks.components.file.input.label')
remove = t('admin.communication.blocks.components.file.input.remove')
hint = file_hint if hint.blank?
accept ||= '*'
%>
<upload-input v-model="<%= model %>.<%= property %>"
              kind="file"
              label="<%= label %>"
              remove="<%= remove %>"
              hint="<%= j hint %>"
              accept="<%= accept %>"
              :size-limit="<%= Rails.application.config.default_file_max_size %>"></upload-input>
