<%
label = t('admin.communication.blocks.components.file.input.label')
remove = t('admin.communication.blocks.components.file.input.remove')
hint = file_hint if hint.blank?
accept ||= '*'
%>
<Picker
  v-model="<%= model %>.<%= property %>"
  endpoint="<%= picker_admin_communication_files_path %>">
</Picker>
<file-upload-input
  v-model="<%= model %>.<%= property %>"
  upload-url="<%= direct_upload_admin_communication_files_path %>"
  label="<%= label %>"
  remove="<%= remove %>"
  hint="<%= j hint %>"
  accept="<%= accept %>"
  :size-limit="<%= Rails.application.config.default_file_max_size %>">
</file-upload-input>
