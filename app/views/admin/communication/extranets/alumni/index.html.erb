<% content_for :title, University::Person::Alumnus.model_name.human(count: 2) %>

<% content_for :title_right do %>
  <%= button_advanced do %>
    <%= link_to t('export'),
                request.params.merge(format: "xlsx"),
                class: button_classes %>
  <% end %>
  <%= link_to t('university.alumni.cohorts.import_btn'),
              new_admin_administration_alumni_cohorts_import_path,
              class: button_classes if can? :create, University::Person::Alumnus %>
<% end %>

<% if @alumni %>
  <div class="d-flex justify-content-between mb-4">
    <p>
      <%= @alumni.total_count %>
      <%= University::Person::Alumnus.model_name.human(count: @alumni.total_count).downcase %>
    </p>
    <%= render 'filters', current_path: admin_communication_extranet_alumni_path %>
  </div>

  <%= render 'admin/communication/extranets/alumni/list', extranet: @extranet, alumni: @alumni %>
  <%= paginate @alumni %>
<% end %>
